# Upwork API credentials
UPWORK_CLIENT_ID=your_upwork_client_id
UPWORK_CLIENT_SECRET=your_upwork_client_secret

# Local development:
# UPWORK_REDIRECT_URI=http://localhost:3000/api/auth/upwork/callback
# Production:
UPWORK_REDIRECT_URI=https://shahid-careerhub.vercel.app/api/auth/upwork/callback

# OpenAI (for embeddings + LLM fallback)
OPENAI_API_KEY=your_openai_api_key

# Anthropic (for /chat primary LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Provider switches — set to false to disable without redeploying (default: true)
ENABLE_ANTHROPIC=true
ENABLE_OPENAI=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Resend (for email digest)
RESEND_API_KEY=re_...
DIGEST_EMAIL=shahid.la@gmail.com

# Langfuse (for LLM observability)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com
