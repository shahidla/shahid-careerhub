# Upwork API credentials
UPWORK_CLIENT_ID=your_upwork_client_id
UPWORK_CLIENT_SECRET=your_upwork_client_secret

# Local development:
# UPWORK_REDIRECT_URI=http://localhost:3000/api/auth/upwork/callback
# Production:
UPWORK_REDIRECT_URI=https://upwork-sepia.vercel.app/api/auth/upwork/callback

# OpenAI (for embeddings)
OPENAI_API_KEY=your_openai_api_key

# Anthropic (for /chat)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
